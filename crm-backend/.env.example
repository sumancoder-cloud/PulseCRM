# MongoDB Connection (Local or Atlas Cluster URI)
# Local: mongodb://127.0.0.1:27017/minicrm
# Atlas: mongodb+srv://username:password@cluster0.mongodb.net/minicrm
MONGODB_URI="mongodb://127.0.0.1:27017/minicrm"

PORT=5000

# Channel Service URL
CHANNEL_SERVICE_URL="http://localhost:5001"

# Gemini API Key for smart segmentation
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=""

# Use mock Gemini for testing (true/false)
USE_MOCK_GEMINI=false

# Frontend URL for CORS (production)
FRONTEND_URL="http://localhost:5173"

# Webhook URL for channel simulator callbacks
CRM_WEBHOOK_URL="http://localhost:5000/api/webhooks/channel"

# Redis Connection URL for BullMQ (optional - uses in-memory queue if empty)
REDIS_URL=""

# Optional — Mock discount for testing
MOCK_DISCOUNT=15
